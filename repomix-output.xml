  NEXT_PUBLIC_APP_URL: z.string().url().default("http://localhost:3000"),
  NEXT_PUBLIC_APP_NAME: z.string().default("Almacén Natural Hunuc Pachacutek"),
  NEXT_PUBLIC_DEFAULT_BRANCH_ID: z.string().optional(),
