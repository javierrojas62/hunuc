import { z } from "zod";

/**
 * Validación de variables de entorno en tiempo de arranque.
 * Falla rápido y claro si falta una variable crítica.
 */
const clientSchema = z.object({
  NEXT_PUBLIC_SUPABASE_URL: z.string().url(),
