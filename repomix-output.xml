create or replace view public.products_view
with (security_invoker = on)
as
select
  p.*,
  c.name  as category_name,
  c.slug  as category_slug,
  c.color as category_color,
  pr.name as producer_name,
  (p.stock <= p.min_stock) as is_low_stock
